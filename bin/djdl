#!/usr/bin/env bash
# djdl — rekordbox-oriented music acquisition workflow around yt-dlp
# Layout:  ~/Music/DJ/{Incoming,.archive.txt,yt-dlp.conf}
set -uo pipefail

DJ_ROOT="${DJ_ROOT:-$HOME/Music/DJ}"
YTDLP="${YTDLP:-$HOME/.local/bin/yt-dlp}"
INCOMING="$DJ_ROOT/Incoming"

c_hd=$'\033[1;36m'; c_ok=$'\033[0;32m'; c_wa=$'\033[0;33m'
c_er=$'\033[0;31m'; c_dm=$'\033[0;90m'; c_rs=$'\033[0m'

die()  { printf "%s✗ %s%s\n" "$c_er" "$*" "$c_rs" >&2; exit 1; }
info() { printf "%s→ %s%s\n" "$c_dm" "$*" "$c_rs" >&2; }
ok()   { printf "%s✓ %s%s\n" "$c_ok" "$*" "$c_rs" >&2; }

[[ -x "$YTDLP" ]] || die "yt-dlp not found at $YTDLP"
mkdir -p "$INCOMING"

# Metadata rules live here, NOT in yt-dlp.conf: that parser strips backslashes
# and lets a multi-arg option swallow the next line as a missing argument,
# which silently produces raw untouched tags. Shell quoting is unambiguous.
META_ARGS=(
  # YouTube dumps the entire video description into comment/description/synopsis.
  # Left alone, that whole wall of text lands in rekordbox's comment column.
  --parse-metadata ":(?P<meta_comment>)"
  --parse-metadata ":(?P<meta_description>)"
  --parse-metadata ":(?P<meta_synopsis>)"

  # Strip title junk. Each bracket must match a junk phrase in FULL, so
  # DJ-critical suffixes — (Extended Mix), (Original Mix), (X Remix) — survive.
  --replace-in-metadata title \
    '(?i)\s*[\(\[]\s*(official\s+(music\s+)?(video|audio)|official\s+visuali[sz]er|lyrics?\s*video|lyrics?|visuali[sz]er|audio only|hd|hq|4k|1080p|free\s+dl|free\s+download|out\s+now|music\s+video)\s*[\)\]]' ''
  # Trailing "| Label / TikTok 2020" tails.
  --replace-in-metadata title '\s*\|\s*[^|]*$' ''
  --replace-in-metadata title '\s+$' ''

  # Split "Artist - Title". Non-greedy, so the FIRST " - " wins:
  # "Artist - Title - Remix" -> artist="Artist", not "Artist - Title".
  # No match (no " - ") is a silent no-op; artist then falls back to
  # uploader via the output template in yt-dlp.conf.
  --parse-metadata 'title:(?P<artist>.+?) - (?P<title>.+)'
)

# All real work funnels through here so -P, the config and META_ARGS are
# never forgotten by an individual subcommand.
# --download-archive must be absolute: -P governs output paths but not the
# archive, so a relative path resolves against CWD and scatters .archive.txt
# across whatever directory you invoked from.
# Hardening, applied to every invocation:
#   --no-plugin-dirs      yt-dlp imports ALL plugins found in user-writable
#                         dirs whether or not they are invoked, performs no
#                         checks on their code, and extractor plugins take
#                         PRIORITY over built-ins — so a dropped file can
#                         silently hijack YouTube handling. No flag needed to
#                         enable them, which is why they must be turned off.
#   --no-remote-components  no fetching of remote JS components at runtime.
# Also note what is deliberately absent everywhere in this script: --exec,
# --netrc-cmd and --write-*-link. --exec in particular has had four separate
# shell-injection breaks; the rule here is never to use it, not to use it
# carefully.
run_dl() {
  "$YTDLP" -P "$DJ_ROOT" --download-archive "$DJ_ROOT/.archive.txt" \
    --no-plugin-dirs --no-remote-components \
    "${META_ARGS[@]}" "$@"
}

# ── search ────────────────────────────────────────────────────────────────
# Queries a provider, renders a numbered table, downloads the chosen rows.
cmd_search() {
  local provider="ytsearch" n=12 label="youtube"
  while [[ "${1:-}" == -* ]]; do
    case "$1" in
      -m|--music) provider="ytmusic"; label="yt-music"; shift ;;
      -s|--sc)    provider="scsearch"; label="soundcloud"; shift ;;
      -n)         n="$2"; shift 2 ;;
      *) die "unknown flag: $1" ;;
    esac
  done
  [[ $# -gt 0 ]] || die "usage: djdl search [-m|-s] [-n N] <query>"

  local query="$*" target
  case "$provider" in
    ytmusic)
      # There is NO `ytmsearch:` prefix in yt-dlp — it fails with
      # "Unsupported url scheme". Plenty of guides claim otherwise; they are
      # wrong. YouTube Music is only reachable through a music.youtube.com
      # search URL, served by the youtube:music:search_url extractor.
      local q; q=$(jq -rn --arg s "$query" '$s|@uri')
      target="https://music.youtube.com/search?q=$q" ;;
    *)
      target="${provider}${n}:${query}" ;;
  esac

  info "searching $label for \"$query\" ..."
  local json
  json=$("$YTDLP" -q --no-warnings --flat-playlist --playlist-end "$n" -j "$target" 2>/dev/null)
  [[ -n "$json" ]] || die "no results (or extractor blocked — try: djdl update)"

  local -a urls=() titles=()
  local i=0
  while IFS=$'\t' read -r url dur uploader title; do
    i=$((i+1)); urls+=("$url"); titles+=("$title")
    local mmss="?:??"
    [[ "$dur" =~ ^[0-9]+$ ]] && mmss=$(printf "%d:%02d" $((dur/60)) $((dur%60)))

    # Flag uploads that are unusable in a DJ set. Pitch/tempo-altered rips are
    # the dangerous ones: rekordbox will happily analyse them and report a key
    # and BPM that are simply wrong, so they poison harmonic mixing silently.
    local warn=""
    case "$title" in
      *432*|*432[Hh]z*)                          warn="pitch-shifted" ;;
      *[Nn]ightcore*|*[Ss]ped[\ _-][Uu]p*)       warn="tempo-altered" ;;
      *[Ss]lowed*|*[Rr]everb*)                   warn="tempo-altered" ;;
    esac
    # A music track running far past ~12 min is almost always a loop or a mix.
    [[ -z "$warn" && "$dur" =~ ^[0-9]+$ && $dur -gt 720 ]] && warn="long/loop?"
    [[ "$title" == *[Ll]ive* ]] && [[ -z "$warn" ]] && warn="live rip"

    local wtag=""
    [[ -n "$warn" ]] && wtag=$(printf "%s ⚠ %-13s%s" "$c_wa" "$warn" "$c_rs")
    printf "%s%3d%s  %s%-7s%s %s%-20.20s%s %s%.52s\n" \
      "$c_hd" "$i" "$c_rs" "$c_dm" "$mmss" "$c_rs" "$c_dm" "${uploader:0:20}" "$c_rs" "$wtag" "$title"
  # YT Music search mixes album/artist browse entries (MPRE… ids, no title)
  # in with tracks; drop anything untitled so the picker only offers playables.
  done < <(echo "$json" | jq -r 'select((.title // "") != "")
    | [(.url // .webpage_url // ("https://youtu.be/"+.id)), (.duration//"?"),
       (.uploader // .channel // .artists[0]? // .uploader_id // "?"), .title] | @tsv')

  [[ $i -gt 0 ]] || die "no parseable results"
  printf "\n%sPick: numbers (1 3 5), range (1-4), 'a' all, Enter cancel: %s" "$c_hd" "$c_rs" >&2
  # Plain stdin read: works when stdin is the terminal AND when a selection
  # is piped in (`echo 2 | djdl search ...`), which is how automation and
  # agents drive it. Reading from /dev/tty instead breaks the piped case —
  # the test can pass while the read itself fails, silently cancelling.
  local pick=""
  read -r pick || true
  [[ -n "${pick// }" ]] || { info "cancelled"; return 0; }

  local -a sel=()
  if [[ "$pick" == "a" ]]; then
    sel=("${urls[@]}")
  else
    for tok in $pick; do
      if [[ "$tok" =~ ^([0-9]+)-([0-9]+)$ ]]; then
        for ((k=${BASH_REMATCH[1]}; k<=${BASH_REMATCH[2]}; k++)); do
          [[ $k -ge 1 && $k -le $i ]] && sel+=("${urls[$((k-1))]}")
        done
      elif [[ "$tok" =~ ^[0-9]+$ && $tok -ge 1 && $tok -le $i ]]; then
        sel+=("${urls[$((tok-1))]}")
      fi
    done
  fi
  [[ ${#sel[@]} -gt 0 ]] || die "nothing selected"
  info "downloading ${#sel[@]} track(s)"
  run_dl "${sel[@]}"
  ok "done → $INCOMING"
}

# ── get ───────────────────────────────────────────────────────────────────
cmd_get() {
  [[ $# -gt 0 ]] || die "usage: djdl get <url> [url...]"
  run_dl "$@" && ok "done → $INCOMING"
}

# ── sync ──────────────────────────────────────────────────────────────────
# Idempotent playlist sync. Re-run any time; the archive skips what you have.
# Note: deliberately NO --break-on-existing — it aborts at the first known
# track, which silently skips everything after a mid-playlist insertion.
cmd_sync() {
  [[ $# -gt 0 ]] || die "usage: djdl sync <playlist-url> [folder-name]"
  local url="$1"; local name="${2:-%(playlist_title,playlist)s}"
  info "syncing into Playlists/$name"
  run_dl -o "Playlists/$name/%(artist,creator,uploader)s - %(title)s.%(ext)s" "$url"
  ok "synced → $DJ_ROOT/Playlists"
}

# ── spotify ───────────────────────────────────────────────────────────────
# spotdl reads Spotify *metadata*, then sources the audio from YouTube.
# It does not decrypt Spotify — the audio is a YouTube match wearing
# Spotify tags. Wrong-version mismatches are the known failure mode.
cmd_spotify() {
  [[ $# -gt 0 ]] || die "usage: djdl spotify <spotify-url>"
  command -v spotdl >/dev/null 2>&1 || die "spotdl not installed. Run: uv tool install spotdl"
  mkdir -p "$INCOMING"
  ( cd "$INCOMING" && spotdl download "$1" \
      --format flac --bitrate disable \
      --output "{artist} - {title}.{output-ext}" )
  ok "done → $INCOMING  ${c_wa}(verify versions — YT matching is imperfect)${c_rs}"
}

# ── vet ───────────────────────────────────────────────────────────────────
# Quality gate. A FLAC container proves nothing about what went into it: a
# 96kbps MP3 re-wrapped as FLAC looks pristine to rekordbox, which will
# happily analyse it and keep it in your library forever.
#
# The tell is spectral. Every lossy encoder lowpasses, and the lower the
# bitrate the lower the cutoff (~15kHz at 96k, ~20kHz for YouTube's 160k Opus).
#
# We measure the SLOPE between 13kHz and 19kHz, NOT the absolute level up
# there. Absolute level is a trap: quiet treble usually just means quiet
# CONTENT. Measured on three real files:
#     genuine bright music   13k=-30.7  19k=-49.6   slope -18.9
#     solo piano (legit)     13k=-56.6  19k=-71.3   slope -14.7
#     96k transcode          13k=-34.7  19k=-79.5   slope -44.8
# The piano sits 26dB lower than the bright track yet has the same gentle
# slope. Only a codec lowpass produces a cliff. An absolute-level threshold
# flags every sparse-treble track — piano, dub, ambient — as fake, which is
# exactly the false positive this replaced.
#
# A gentle `highpass` is useless here: it leaks bass into the measurement and
# collapses the gap to ~3dB, hence the 4-stage 2-pole chain per probe point.
hp_at() { printf 'highpass=f=%s:poles=2,highpass=f=%s:poles=2,highpass=f=%s:poles=2,highpass=f=%s:poles=2' "$1" "$1" "$1" "$1"; }

cmd_vet() {
  local dir="${1:-$INCOMING}"
  [[ -d "$dir" ]] || die "not a directory: $dir"

  local -a files=()
  while IFS= read -r -d '' f; do files+=("$f"); done < <(
    find "$dir" -type f \( -name '*.flac' -o -name '*.m4a' -o -name '*.mp3' \
      -o -name '*.wav' -o -name '*.aiff' -o -name '*.alac' \) -print0 2>/dev/null)
  [[ ${#files[@]} -gt 0 ]] || { info "no audio files in $dir"; return 0; }

  printf "%s%-34s %-6s %5s %7s %7s  %s%s\n" "$c_hd" \
    "TRACK" "CODEC" "kHz" "LUFS" "PEAK" "VERDICT" "$c_rs"

  local f base probe codec sr ch dur full hi delta lufs peak rms_l rms_r
  for f in "${files[@]}"; do
    base=$(basename "$f"); base="${base%.*}"
    probe=$(ffprobe -v quiet -select_streams a:0 \
      -show_entries stream=codec_name,sample_rate,channels:format=duration \
      -of default=nw=1:nk=1 "$f" 2>/dev/null)
    codec=$(sed -n 1p <<<"$probe"); sr=$(sed -n 2p <<<"$probe")
    ch=$(sed -n 3p <<<"$probe");    dur=$(sed -n 4p <<<"$probe")

    # Analyse a 60s window from 0:30 — skips intros/silence, bounds runtime.
    local seek=(-ss 30 -t 60)
    [[ "${dur%%.*}" -lt 100 ]] 2>/dev/null && seek=()

    local hi13 hi19
    full=$(ffmpeg -hide_banner -nostats "${seek[@]}" -i "$f" -af volumedetect -f null - 2>&1 \
      | grep -m1 mean_volume | grep -oE '\-?[0-9.]+ dB' | grep -oE '\-?[0-9.]+')
    hi13=$(ffmpeg -hide_banner -nostats "${seek[@]}" -i "$f" -af "$(hp_at 13000),volumedetect" -f null - 2>&1 \
      | grep -m1 mean_volume | grep -oE '\-?[0-9.]+ dB' | grep -oE '\-?[0-9.]+')
    hi19=$(ffmpeg -hide_banner -nostats "${seek[@]}" -i "$f" -af "$(hp_at 19000),volumedetect" -f null - 2>&1 \
      | grep -m1 mean_volume | grep -oE '\-?[0-9.]+ dB' | grep -oE '\-?[0-9.]+')

    local eb
    eb=$(ffmpeg -hide_banner -nostats "${seek[@]}" -i "$f" -af ebur128=peak=true -f null - 2>&1)
    lufs=$(grep -A6 'Integrated loudness' <<<"$eb" | grep -m1 ' I: ' | grep -oE '\-?[0-9.]+')
    peak=$(grep -A3 'True peak' <<<"$eb" | grep -m1 'Peak:' | grep -oE '\-?[0-9.]+')

    # slope = how fast energy falls from 13kHz to 19kHz. A codec lowpass is a
    # cliff; real content — however dark — tapers.
    delta=""
    if [[ -n "$hi13" && -n "$hi19" ]]; then
      delta=$(python3 -c "print(round($hi19-($hi13),1))" 2>/dev/null)
    fi

    # Verdicts, worst-first. Thresholds sit between the measured genuine
    # cases (-14.7, -18.9) and the measured transcode (-44.8), with margin.
    local verdict="" vcol="$c_ok"
    if [[ -n "$delta" ]]; then
      if   (( $(python3 -c "print(1 if $delta <= -35 else 0)") )); then
        verdict="lossy source (~<128k)"; vcol="$c_er"
      elif (( $(python3 -c "print(1 if $delta <= -28 else 0)") )); then
        verdict="marginal HF"; vcol="$c_wa"
      else
        verdict="ok"; vcol="$c_ok"
      fi
    else verdict="unanalysed"; vcol="$c_dm"; fi

    # Dual mono: two identical channels, i.e. no stereo image at all on a
    # club rig. Tested via the SIDE signal (L-R): if it is effectively
    # silent the channels are identical. Comparing per-channel RMS instead
    # is wrong — a wide stereo mix can have near-equal RMS per channel.
    if [[ "$ch" == "2" ]]; then
      local side
      side=$(ffmpeg -hide_banner -nostats "${seek[@]}" -i "$f" \
        -af "pan=mono|c0=0.5*FL-0.5*FR,volumedetect" -f null - 2>&1 \
        | grep -m1 mean_volume | sed 's/.*mean_volume: *//' | grep -oE '^\-?[0-9.]+')
      if [[ -n "$side" ]] && (( $(python3 -c "print(1 if $side < -70 else 0)" 2>/dev/null || echo 0) )); then
        verdict="$verdict, dual-mono"; [[ "$vcol" == "$c_ok" ]] && vcol="$c_wa"
      fi
    elif [[ "$ch" == "1" ]]; then
      verdict="$verdict, MONO"; [[ "$vcol" == "$c_ok" ]] && vcol="$c_wa"
    fi

    # True peak over 0 dBTP will clip on D/A conversion and on the CDJ's
    # own limiter. Common in loud masters, but you want to know before it
    # is in the mix.
    if [[ -n "$peak" ]] && (( $(python3 -c "print(1 if $peak > 0.0 else 0)" 2>/dev/null || echo 0) )); then
      verdict="$verdict, +peak"; [[ "$vcol" == "$c_ok" ]] && vcol="$c_wa"
    fi

    printf "%-34.34s %-6s %5s %7s %7s  %s%s%s\n" \
      "$base" "$codec" "$((${sr:-0}/1000))" "${lufs:-?}" "${peak:-?}" "$vcol" "$verdict" "$c_rs"
  done
  printf "%s13k→19k slope: >-28 ok · -28..-35 marginal · <-35 codec cliff (lossy source)%s\n" "$c_dm" "$c_rs"
}

# ── scan ──────────────────────────────────────────────────────────────────
# Integrity / safety checks on downloaded files. Deliberately NOT an
# antivirus: the realistic risks for audio pulled by yt-dlp are a truncated
# or corrupt file, a container that isn't what its extension claims, and
# malformed embedded cover art (image parsers are a far bigger attack
# surface than audio decoders). Each check below either passes or names
# something concrete — nothing here is decorative.
cmd_scan() {
  local dir="${1:-$INCOMING}"
  [[ -d "$dir" ]] || die "not a directory: $dir"

  local -a files=()
  while IFS= read -r -d '' f; do files+=("$f"); done < <(
    find "$dir" -type f \( -name '*.flac' -o -name '*.m4a' -o -name '*.mp3' \
      -o -name '*.wav' -o -name '*.aiff' \) -print0 2>/dev/null)
  [[ ${#files[@]} -gt 0 ]] || { info "no audio files in $dir"; return 0; }

  local bad=0
  for f in "${files[@]}"; do
    local base issues=() ext mime probe magic
    base=$(basename "$f"); ext="${f##*.}"
    ext=$(tr 'A-Z' 'a-z' <<<"$ext")

    # 1. Does the container match the extension? Catches a renamed file or a
    #    polyglot whose extension misrepresents its real contents.
    mime=$(file -b --mime-type "$f" 2>/dev/null)

    # ffprobe is NOT authoritative for content type — it falls back to
    # extension-based detection. A shell script named .flac probes as "flac".
    # It does warn ("Format flac detected only with low score of 1"), but at
    # warning level, so `-v quiet` hides exactly the signal that matters.
    # file(1) is the authority; ffprobe's low-score line is corroboration.
    local probe_raw
    probe_raw=$(ffprobe -v warning -show_entries format=format_name -of csv=p=0 "$f" 2>&1)
    probe=$(tail -1 <<<"$probe_raw")
    grep -q 'low score' <<<"$probe_raw" && \
      issues+=("ffprobe low-score detection — extension misrepresents contents")
    [[ -z "$probe" ]] && issues+=("not decodable as audio")
    case "$ext" in
      flac) [[ "$mime" == audio/flac  || "$probe" == *flac* ]] || issues+=("ext/container mismatch: $mime/$probe") ;;
      m4a)  [[ "$mime" == audio/*     || "$probe" == *mp4*  ]] || issues+=("ext/container mismatch: $mime/$probe") ;;
      mp3)  [[ "$mime" == audio/mpeg  || "$probe" == *mp3*  ]] || issues+=("ext/container mismatch: $mime/$probe") ;;
    esac

    # 2. Executable magic inside something claiming to be audio. Mach-O,
    #    ELF, PE and shebangs have no business at the head of a music file.
    magic=$(xxd -l 4 -p "$f" 2>/dev/null)
    case "$magic" in
      cffaedfe|cefaedfe|feedface|feedfacf|cafebabe) issues+=("MACH-O EXECUTABLE HEADER") ;;
      7f454c46) issues+=("ELF EXECUTABLE HEADER") ;;
      4d5a*)    issues+=("PE/DOS EXECUTABLE HEADER") ;;
      2321*)    issues+=("SHEBANG — script, not audio") ;;
    esac

    # 3. Full decode. Truncated or corrupt files import into rekordbox and
    #    then fail mid-set, which is the worst possible time to find out.
    local derr
    derr=$(ffmpeg -v error -i "$f" -f null - 2>&1 | head -2)
    [[ -n "$derr" ]] && issues+=("decode errors: $(tr '\n' ' ' <<<"$derr" | cut -c1-60)")

    # 4. Embedded cover art must be a real image. A malformed one is the
    #    most plausible hostile payload in a music file, since it is handed
    #    straight to an image parser by every player that shows artwork.
    if ffprobe -v quiet -select_streams v -show_entries stream=codec_name -of csv=p=0 "$f" 2>/dev/null | grep -q .; then
      local tmpimg="${TMPDIR:-/tmp}/djdl_art_$$"
      if ffmpeg -v error -y -i "$f" -an -vcodec copy -f image2 "$tmpimg" 2>/dev/null; then
        file -b "$tmpimg" 2>/dev/null | grep -qiE 'image|bitmap' || issues+=("embedded art is NOT a valid image")
      fi
      rm -f "$tmpimg"
    fi

    # 5. Foreign payload appended after the audio stream — the polyglot
    #    pattern used in real campaigns: a file that is simultaneously a
    #    playable MP3 and an executable script. Players read from offset 0
    #    and play it; another interpreter scans deeper and executes.
    #    Reporting the byte OFFSET is the point — it marks where the audio
    #    ended and something else began. Note the payload half of these is
    #    typically Windows-targeted and inert on macOS, but a hit is a
    #    high-confidence "deliberately constructed" signal either way.
    #    Do NOT try to derive this from ffprobe packet offsets: the demuxer
    #    absorbs appended junk, so trailing bytes always compute to zero.
    local hit
    hit=$(LC_ALL=C grep -aboE 'PK\x03\x04|PK\x05\x06|\x7fELF|<script|<html|<HTA:|#!/bin/|mshta|powershell' "$f" 2>/dev/null | head -1)
    [[ -n "$hit" ]] && issues+=("foreign payload at byte offset ${hit%%:*}")

    # 6. macOS quarantine. PROVENANCE ONLY, never a verdict: opening a
    #    quarantined non-executable triggers no Gatekeeper check, and
    #    yt-dlp doesn't set the xattr at all — so its absence means nothing.
    xattr -p com.apple.quarantine "$f" >/dev/null 2>&1 && issues+=("quarantine xattr — arrived via browser/AirDrop, not yt-dlp")

    if [[ ${#issues[@]} -eq 0 ]]; then
      printf "%s  ✓%s %.60s\n" "$c_ok" "$c_rs" "$base"
    else
      bad=$((bad+1))
      printf "%s  ✗%s %.60s\n" "$c_er" "$c_rs" "$base"
      local i; for i in "${issues[@]}"; do printf "%s      %s%s\n" "$c_wa" "$i" "$c_rs"; done
    fi
  done
  echo
  if [[ $bad -eq 0 ]]; then
    # Deliberately not a green "SAFE" badge. These checks cover file-shape
    # problems; they do not and cannot cover malformed-bitstream parser
    # exploits (e.g. the CoreAudio zero-click class), where the trigger is
    # indistinguishable from ordinary corruption. Implying otherwise would
    # be exactly the theater this is trying to avoid.
    printf "%s%d file(s): no structural problems found%s\n" "$c_ok" "${#files[@]}" "$c_rs"
  else
    printf "%s%d of %d file(s) have issues%s\n" "$c_er" "$bad" "${#files[@]}" "$c_rs"
  fi
  cat <<EOF
${c_dm}This checks file shape, not exploits. Parser-level attacks are undetectable
by scanning — the control for those is patching macOS and ffmpeg.
The larger real risk is supply chain: yt-dlp and spotdl execute code on this
machine. Run 'djdl doctor' for those checks.${c_rs}
EOF
}

# ── analyze ───────────────────────────────────────────────────────────────
# BPM + loudness per track, cached. rekordbox does its own authoritative
# analysis on import, so this exists to inform decisions BEFORE that —
# which tracks sit in the same tempo range, and how loud they are relative
# to each other for gain staging.
ANALYSIS="$DJ_ROOT/.analysis.tsv"
ENGINE="${YTDLP%/*}/djdl-engine"
ENGINE_PY="$HOME/.local/share/muse-venv/bin/python"

cmd_analyze() {
  [[ -x "$ENGINE_PY" ]] || die "muse venv missing. Run: uv venv --python 3.14 ~/.local/share/muse-venv && VIRTUAL_ENV=~/.local/share/muse-venv uv pip install essentia"
  local dir="${1:-$INCOMING}"
  [[ -d "$dir" ]] || die "not a directory: $dir"
  local -a files=()
  while IFS= read -r -d '' f; do files+=("$f"); done < <(
    find "$dir" -type f \( -name '*.flac' -o -name '*.m4a' -o -name '*.mp3' \
      -o -name '*.wav' -o -name '*.aiff' \) -print0 2>/dev/null)
  [[ ${#files[@]} -gt 0 ]] || { info "no audio files in $dir"; return 0; }

  info "analysing ${#files[@]} track(s) with Essentia (BPM + key) ..."
  "$ENGINE_PY" "$ENGINE" analyze "${files[@]}" > "$ANALYSIS"

  printf "%s%-42s %7s %6s %6s %6s%s\n" "$c_hd" "TRACK" "BPM" "CONF" "KEY" "CLASS" "$c_rs"
  # Low rhythm confidence means the BPM is a guess — beatless or rubato
  # material. A trailing * on key confidence means the two key profiles
  # disagreed, which is the honest signal that the key is unreliable.
  tail -n +2 "$ANALYSIS" | while IFS=$'\t' read -r path bpm conf cam cls kc; do
    local b col
    b=$(basename "$path"); b="${b%.*}"
    col="$c_ok"
    awk -v c="$conf" 'BEGIN{exit !(c<1.5)}' && col="$c_wa"
    printf "%-42.42s %7s %s%6s%s %6s %6s\n" "$b" "$bpm" "$col" "$conf" "$c_rs" "$cam" "$cls"
  done
  printf "%sconf <1.5 = unreliable BPM (beatless/rubato) · key* = profiles disagreed%s\n" "$c_dm" "$c_rs"
  printf "%scached in %s%s\n" "$c_dm" "$ANALYSIS" "$c_rs"
}

# ── similar ───────────────────────────────────────────────────────────────
# Deezer related-artists. Keyless: no signup, no token, no OAuth. Chosen over
# Spotify (whose /recommendations and /audio-features were withdrawn for new
# apps in Nov 2024), ListenBrainz (weaker on electronic) and Last.fm (whose
# ToS caps stored data, so a cached similarity graph would breach it).
cmd_similar() {
  [[ $# -gt 0 ]] || die "usage: djdl similar <artist>"
  "$ENGINE_PY" "$ENGINE" similar "$@"
}

# ── mix ───────────────────────────────────────────────────────────────────
# Rank the analysed library by how well each track follows a seed.
cmd_mix() {
  [[ -f "$ANALYSIS" ]] || die "no analysis yet — run: djdl analyze"
  local seed_bpm seed_key
  if [[ "${1:-}" =~ ^[0-9.]+$ ]]; then
    seed_bpm="$1"; seed_key="${2:-8A}"
  else
    [[ $# -gt 0 ]] || die "usage: djdl mix <bpm> <camelot> | djdl mix <track-substring>"
    local row; row=$(grep -i -m1 -F "$1" "$ANALYSIS") || die "no analysed track matching: $1"
    seed_bpm=$(cut -f2 <<<"$row"); seed_key=$(cut -f4 <<<"$row")
    local seed_path; seed_path=$(cut -f1 <<<"$row")
    info "seed: $(basename "$seed_path")  ${seed_bpm} BPM  ${seed_key}"
    # Exclude the seed from its own ranking — it would always score 100.
    grep -vF "$seed_path" "$ANALYSIS" | "$ENGINE_PY" "$ENGINE" compat "$seed_bpm" "$seed_key"
    return
  fi
  "$ENGINE_PY" "$ENGINE" compat "$seed_bpm" "$seed_key" < "$ANALYSIS"
}

# ── gain ──────────────────────────────────────────────────────────────────
# Writes ReplayGain 2.0 tags (EBU R128, -18 LUFS reference) in place.
cmd_gain() {
  command -v rsgain >/dev/null 2>&1 || die "rsgain not installed. Run: brew install rsgain"
  local dir="${1:-$INCOMING}"
  [[ -d "$dir" ]] || die "not a directory: $dir"
  info "writing ReplayGain 2.0 tags (track gain, EBU R128) ..."
  rsgain easy "$dir"
  ok "tagged → $dir"
}

# ── rbxml ─────────────────────────────────────────────────────────────────
# Emits a rekordbox-importable XML collection. Import is ADDITIVE and
# non-destructive: rekordbox shows it as a separate browsable panel and
# nothing enters the real collection until you explicitly import. Tracks are
# referenced in place, never copied.
cmd_rbxml() {
  local helper="${YTDLP%/*}/djdl-rbxml"
  [[ -x "$helper" ]] || die "djdl-rbxml not found next to djdl"
  DJ_ROOT="$DJ_ROOT" "$helper" "$@" || return 1
  cat <<EOF

${c_hd}To import in rekordbox 7:${c_rs}
  1. Preferences > View > Layout    -> tick "rekordbox xml"
  2. Preferences > Advanced > Database > Imported Library > Browse
     -> select ${DJ_ROOT}/rekordbox.xml
  3. The tree appears in the left sidebar under "rekordbox xml".
     Right-click tracks > "Import To Collection".

${c_wa}Known rekordbox bug:${c_rs} tracks already in your collection are NOT updated
on re-import. Select the tracks inside the playlist and import those, rather
than importing the playlist node, or the update is silently skipped.
EOF
}

# ── housekeeping ──────────────────────────────────────────────────────────
cmd_ls() {
  local count; count=$(find "$INCOMING" -type f \
    \( -name '*.flac' -o -name '*.m4a' -o -name '*.mp3' -o -name '*.wav' \) 2>/dev/null | wc -l | tr -d ' ')
  printf "%s%s track(s) in Incoming%s\n" "$c_hd" "$count" "$c_rs"
  find "$INCOMING" -type f \( -name '*.flac' -o -name '*.m4a' -o -name '*.mp3' \) \
    -exec ls -lh {} + 2>/dev/null | awk '{printf "  %-7s %s\n", $5, substr($0, index($0,$9))}' | sort -k2
  printf "%sarchive: %s entries%s\n" "$c_dm" \
    "$(wc -l < "$DJ_ROOT/.archive.txt" 2>/dev/null | tr -d ' ' || echo 0)" "$c_rs"
}

cmd_update() { "$YTDLP" --update-to nightly; }

cmd_doctor() {
  printf "%s── djdl doctor ──%s\n" "$c_hd" "$c_rs"
  printf "  yt-dlp   %s\n" "$("$YTDLP" --version 2>/dev/null || echo MISSING)"
  printf "  ffmpeg   %s\n" "$(ffmpeg -version 2>/dev/null | head -1 | awk '{print $3}' || echo MISSING)"
  printf "  jq       %s\n" "$(command -v jq >/dev/null && echo ok || echo MISSING)"
  printf "  spotdl   %s\n" "$(command -v spotdl >/dev/null && echo ok || echo '- (uv tool install spotdl)')"
  printf "  config   %s\n" "$([[ -f "$DJ_ROOT/yt-dlp.conf" ]] && echo ok || echo MISSING)"
  printf "  free     %s\n" "$(df -h "$DJ_ROOT" | tail -1 | awk '{print $4}')"
  # ── supply chain ────────────────────────────────────────────────────────
  # This matters more than scanning the audio files. yt-dlp and spotdl
  # execute code here; the downloaded FLACs do not.
  printf "\n%s── supply chain ──%s\n" "$c_hd" "$c_rs"

  # ffmpeg < 8.1.2 carries CVE-2026-8461 (heap OOB write in the MagicYUV
  # decoder, RCE demonstrated from a 50KB file). `djdl scan` and `vet` both
  # decode untrusted input, so a stale ffmpeg turns those into a liability.
  # Strictly-less-than: `sort -V -C` alone treats equal as sorted, so an
  # exactly-patched version would report as vulnerable.
  local fv; fv=$(ffmpeg -version 2>/dev/null | head -1 | awk '{print $3}')
  if [[ -n "$fv" && "$fv" != "8.1.2" ]] && printf '%s\n8.1.2\n' "$fv" | sort -V -C; then
    printf "  %sffmpeg %s < 8.1.2 — CVE-2026-8461 (RCE via crafted media).%s\n" "$c_er" "$fv" "$c_rs"
    printf "  %sFix: brew upgrade ffmpeg%s\n" "$c_wa" "$c_rs"
  else
    printf "  %s✓%s ffmpeg %s (>= 8.1.2, PixelSmash patched)\n" "$c_ok" "$c_rs" "$fv"
  fi

  # yt-dlp advisory floor: 2026.07.04 fixes the --exec shell-injection
  # (GHSA-69qj-pvh9-c5wg) and --write-link (CVE-2026-55404).
  local yv; yv=$("$YTDLP" --version 2>/dev/null | cut -d@ -f1)
  if [[ -n "$yv" ]] && printf '%s\n2026.07.04\n' "$yv" | sort -V -C && [[ "$yv" != "2026.07.04" ]]; then
    printf "  %s⚠%s yt-dlp %s is below the 2026.07.04 advisory floor — run: djdl update\n" "$c_wa" "$c_rs" "$yv"
  else
    printf "  %s✓%s yt-dlp %s (>= 2026.07.04 advisory floor)\n" "$c_ok" "$c_rs" "$yv"
  fi

  # Plugins are arbitrary Python, imported whether or not invoked, with no
  # code checks, and extractor plugins OVERRIDE built-ins. djdl passes
  # --no-plugin-dirs on every call, so this is belt-and-braces.
  local pd
  pd=$("$YTDLP" --ignore-config -v --simulate "https://youtu.be/jNQXAC9IVRw" 2>&1 \
       | grep -m1 'Plugin directories:' | sed 's/.*Plugin directories: //')
  if [[ "$pd" == "none" || -z "$pd" ]]; then
    printf "  %s✓%s no yt-dlp plugin directories present\n" "$c_ok" "$c_rs"
  else
    printf "  %s⚠%s yt-dlp plugins found: %s — these auto-execute and override extractors\n" "$c_wa" "$c_rs" "$pd"
  fi
  printf "  %s✓%s djdl hardening: --no-plugin-dirs --no-remote-components, never --exec\n" "$c_ok" "$c_rs"

  printf "\n"
  info "probing YouTube extractor ..."
  if "$YTDLP" -q --no-warnings --no-plugin-dirs --simulate "https://www.youtube.com/watch?v=jNQXAC9IVRw" 2>/dev/null; then
    ok "extractor healthy (no PO token needed)"
  else
    printf "%s⚠ extraction failed — run 'djdl update' first; if it persists you may\n" "$c_wa"
    printf "  need cookies (--cookies-from-browser safari) or the PO token plugin.%s\n" "$c_rs"
  fi
}

case "${1:-help}" in
  search|s)  shift; cmd_search "$@" ;;
  get|g)     shift; cmd_get "$@" ;;
  sync)      shift; cmd_sync "$@" ;;
  spotify|sp) shift; cmd_spotify "$@" ;;
  vet|v)     shift; cmd_vet "$@" ;;
  scan)      shift; cmd_scan "$@" ;;
  analyze|an) shift; cmd_analyze "$@" ;;
  gain)      shift; cmd_gain "$@" ;;
  rbxml|xml) shift; cmd_rbxml "$@" ;;
  similar|sim) shift; cmd_similar "$@" ;;
  mix|next)  shift; cmd_mix "$@" ;;
  ls|list)   cmd_ls ;;
  update|up) cmd_update ;;
  doctor|dr) cmd_doctor ;;
  *) cat <<EOF
${c_hd}djdl${c_rs} — rekordbox-oriented music acquisition

  ${c_hd}search${c_rs} [-m|-s] [-n N] <query>   search + pick + download
                                   -m YouTube Music (cleanest tags)
                                   -s SoundCloud   (edits, bootlegs)
  ${c_hd}get${c_rs} <url>...                    download URLs directly
  ${c_hd}sync${c_rs} <playlist> [name]          idempotent playlist sync
  ${c_hd}spotify${c_rs} <url>                   Spotify playlist via spotdl
  ${c_hd}vet${c_rs} [dir]                       quality gate: detects lossy
                                   sources laundered into FLAC, dual-mono,
                                   clipping; reports LUFS for gain staging
  ${c_hd}scan${c_rs} [dir]                      integrity check: container vs
                                   extension, executable headers, decode
                                   errors, malformed cover art, quarantine
  ${c_hd}analyze${c_rs} [dir]                   BPM + key (Camelot) via Essentia
  ${c_hd}mix${c_rs} <track|bpm camelot>         rank library by what mixes next
  ${c_hd}similar${c_rs} <artist>                related artists (Deezer, keyless)
  ${c_hd}gain${c_rs} [dir]                      write ReplayGain 2.0 tags
  ${c_hd}rbxml${c_rs} [dir] [out.xml]           export a rekordbox XML collection
  ${c_hd}ls${c_rs}                              what's staged in Incoming
  ${c_hd}update${c_rs}                          yt-dlp -> nightly
  ${c_hd}doctor${c_rs}                          health check

Everything lands in ${DJ_ROOT}/Incoming as FLAC or stream-copied
m4a/mp3 — never Opus, which rekordbox cannot import.
EOF
  ;;
esac
